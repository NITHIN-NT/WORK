rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check for authentication
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helpers to check roles and association
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isClient() {
      return isAuthenticated() && getUserData().role == 'Client stakeholder';
    }

    function getClientCompanyId() {
      return getUserData().companyId;
    }

    // Helper to check if a user is accessing their own UID document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Project Documents
    match /projects/{projectId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in resource.data.memberIds || 
        (isClient() && resource.data.clientId == getClientCompanyId())
      );
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        request.auth.uid in resource.data.memberIds ||
        (isClient() && resource.data.clientId == getClientCompanyId())
      );
      allow delete: if isAuthenticated() && request.auth.uid in resource.data.memberIds;
      
      // Subcollections
      match /{allSubcollections=**} {
        allow read: if isAuthenticated() && (
          request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds ||
          (isClient() && get(/databases/$(database)/documents/projects/$(projectId)).data.clientId == getClientCompanyId())
        );
        allow write: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/projects/$(projectId)).data.memberIds;
      }
    }

    // Invoices
    match /invoices/{invoiceId} {
      allow read: if isAuthenticated() && (
        !isClient() || resource.data.clientId == getClientCompanyId()
      );
      allow write: if isAuthenticated() && !isClient();
    }

    // Tasks 
    match /tasks/{taskId} {
      allow read: if isAuthenticated() && (
        !isClient() || get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.clientId == getClientCompanyId()
      );
      allow write: if isAuthenticated() && !isClient();
    }

    // Global Collections
    match /clients/{clientId} {
      allow read: if isAuthenticated() && (
        !isClient() || clientId == getClientCompanyId()
      );
      allow write: if isAuthenticated() && !isClient();
    }

    match /calendar_events/{eventId} {
      allow read, write: if isAuthenticated() && !isClient();
    }

    // User profiles
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }
  }
}
